# ============================================================
#  ContextChain v4 — Environment Variables
#  Copy this file to .env and fill in your keys
# ============================================================

# ── AIML API ─────────────────────────────────────────────────────────────────
# Used by: Agent 1 (Needs Analyzer) + Agent 3 (Risk Auditor)
# Model:   deepseek/deepseek-r1  (reasoning model)
# Get key: https://aimlapi.com
AIMLAPI_KEY=your_aimlapi_key_here

# ── Featherless AI ────────────────────────────────────────────────────────────
# Used by: Agent 2 (Vendor Intelligence)
# Model:   featherless-ai/Qwen2.5-72B-Instruct  (open-source, structured output)
# Get key: https://featherless.ai
FEATHERLESS_API_KEY=your_featherless_key_here

# ── OpenAI (fallback only) ───────────────────────────────────────────────────
# If AIMLAPI_KEY or FEATHERLESS_API_KEY are missing,
# those agents automatically fall back to gpt-4o-mini via OpenAI.
# You can run the whole system with just this key during development.
OPENAI_API_KEY=your_openai_key_here
